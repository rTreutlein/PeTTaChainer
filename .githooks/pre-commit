#!/usr/bin/env bash
set -euo pipefail

if ! command -v mettafmt >/dev/null 2>&1; then
  echo "pre-commit: mettafmt not found in PATH" >&2
  echo "Install mettafmt or bypass with: git commit --no-verify" >&2
  exit 1
fi

mapfile -t metta_files < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.metta$' || true)

if [ ${#metta_files[@]} -eq 0 ]; then
  exit 0
fi

existing_files=()
for f in "${metta_files[@]}"; do
  if [ -f "$f" ]; then
    existing_files+=("$f")
  fi
done

if [ ${#existing_files[@]} -eq 0 ]; then
  exit 0
fi

for f in "${existing_files[@]}"; do
  mettafmt "$f"
done

git add -- "${existing_files[@]}"
